#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
covered="$(mktemp)"
uncovered="$(mktemp)"
trap 'rm -f "$covered" "$uncovered"' EXIT

printf '%s\n' SF:covered.rs DA:1,1 DA:2,1 LF:2 LH:1 end_of_record >"$covered"
printf '%s\n' SF:uncovered.rs DA:1,1 DA:2,0 LF:2 LH:1 end_of_record >"$uncovered"

"$script_dir/check-lcov-lines.awk" "$covered"
if "$script_dir/check-lcov-lines.awk" "$uncovered"; then
    echo "uncovered source line passed the LCOV gate" >&2
    exit 1
fi
