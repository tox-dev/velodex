{
  "openapi": "3.1.0",
  "info": {
    "title": "velodex",
    "description": "PyPI-compatible read-through cache and private index. Every configured index route serves the same surface; `{route}` is the index's route, for example `root/pypi`. Write operations authenticate with HTTP Basic where the password is the target local index's upload token and the username is ignored.",
    "contact": {
      "name": "tox-dev",
      "url": "https://github.com/tox-dev/velodex"
    },
    "license": {
      "name": "MIT"
    },
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:4433",
      "description": "A local velodex with the default configuration"
    }
  ],
  "paths": {
    "/+api": {
      "get": {
        "tags": [
          "discovery"
        ],
        "summary": "Discover this server",
        "description": "A compact server document with global URLs and one discovery entry per configured index. It is built from configuration and request context, without reading package indexes.",
        "responses": {
          "200": {
            "description": "The server discovery document",
            "content": {
              "application/json": {
                "example": {
                  "indexes": [],
                  "urls": {
                    "api": "http://127.0.0.1:4433/+api",
                    "openapi": "http://127.0.0.1:4433/api-docs/openapi.json",
                    "stats": "http://127.0.0.1:4433/+stats",
                    "status": "http://127.0.0.1:4433/+status",
                    "web": "http://127.0.0.1:4433/"
                  },
                  "version": "0.0.1"
                }
              }
            }
          }
        }
      }
    },
    "/+stats": {
      "get": {
        "tags": [
          "operations"
        ],
        "summary": "Usage statistics",
        "description": "Counters aggregated off the request path, drillable: no parameters for per-index totals, `?index={route}` for one index's projects, `&project={name}` for one project's files. Counters cover pages, downloads (with bytes), metadata, uploads, refreshes, upstream changes, stale fallbacks, upstream errors, and rejected downloads.",
        "parameters": [
          {
            "name": "index",
            "in": "query",
            "description": "Drill into one index's projects",
            "required": false,
            "example": "root/pypi"
          },
          {
            "name": "project",
            "in": "query",
            "description": "With `index`, drill into one project's files",
            "required": false,
            "example": "pandas"
          }
        ],
        "responses": {
          "200": {
            "description": "The counters at the requested depth",
            "content": {
              "application/json": {
                "example": {
                  "root/pypi": {
                    "bytes": 64733247,
                    "changed": 1,
                    "downloads": 6,
                    "metadata": 6,
                    "pages": 12,
                    "refreshes": 2,
                    "rejected": 0,
                    "stale_served": 0,
                    "uploads": 0,
                    "upstream_errors": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/+status": {
      "get": {
        "tags": [
          "operations"
        ],
        "summary": "Health and identity",
        "description": "Version, counters, and the configured indexes; the web UI's live dashboard refreshes from this.",
        "responses": {
          "200": {
            "description": "The status document",
            "content": {
              "application/json": {
                "example": {
                  "indexes": [
                    {
                      "kind": "mirror",
                      "layers": [],
                      "name": "pypi",
                      "route": "pypi",
                      "upload_to": null,
                      "uploads": false,
                      "volatile_deletes": false
                    },
                    {
                      "kind": "local",
                      "layers": [],
                      "name": "local",
                      "route": "local",
                      "upload_to": null,
                      "uploads": true,
                      "volatile_deletes": true
                    },
                    {
                      "kind": "overlay",
                      "layers": [
                        "local",
                        "pypi"
                      ],
                      "name": "root/pypi",
                      "route": "root/pypi",
                      "upload_to": "local",
                      "uploads": true,
                      "volatile_deletes": true
                    }
                  ],
                  "metadata_requests": 37,
                  "requests": 128,
                  "serial": 42,
                  "version": "0.0.1"
                }
              }
            }
          }
        }
      }
    },
    "/api-docs/openapi.json": {
      "get": {
        "tags": [
          "operations"
        ],
        "summary": "This document",
        "responses": {
          "200": {
            "description": "The OpenAPI 3.1 description of this server",
            "content": {
              "application/json": {}
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": [
          "operations"
        ],
        "summary": "Prometheus metrics",
        "responses": {
          "200": {
            "description": "Prometheus text exposition",
            "content": {
              "text/plain; version=0.0.4": {
                "example": "# HELP velodex_requests_total Total HTTP requests served.\n# TYPE velodex_requests_total counter\nvelodex_requests_total 128\n# HELP velodex_metadata_requests_total PEP 658 .metadata siblings served.\n# TYPE velodex_metadata_requests_total counter\nvelodex_metadata_requests_total 37\n"
              }
            }
          }
        }
      }
    },
    "/{route}/": {
      "post": {
        "tags": [
          "publish"
        ],
        "summary": "Upload a distribution",
        "description": "The legacy PyPI upload API, as sent by `twine upload` and `uv publish`. The multipart form's `content` part carries a wheel or modern `.tar.gz` sdist. velodex streams the bytes to a staged blob, verifies declared `sha256_digest` and `blake2_256_digest` values, then checks filename, archive, wheel `.dist-info` structure, RECORD hashes, and core-metadata identity before the file lands in the index's local layer. The upload shadows any upstream file of the same name.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          }
        ],
        "requestBody": {
          "description": "`multipart/form-data` with `:action=file_upload`",
          "content": {
            "multipart/form-data": {
              "example": {
                ":action": "file_upload",
                "blake2_256_digest": "5c7d8a29df3e0c4c752c02bff90615dd08d1d1aa9e23738a1e50c27f0415f95d",
                "content": "<the distribution file>",
                "filetype": "bdist_wheel",
                "name": "velodexpkg",
                "requires_python": ">=3.8",
                "sha256_digest": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08",
                "version": "1.0"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stored",
            "content": {
              "text/plain": {
                "example": "upload accepted"
              }
            }
          },
          "400": {
            "description": "Rejected",
            "content": {
              "text/plain": {
                "example": "metadata Name \"other\" does not match upload name \"velodexpkg\""
              }
            }
          },
          "401": {
            "description": "Missing or wrong token"
          },
          "403": {
            "description": "Uploads disabled: the local index has no `upload_token`"
          },
          "405": {
            "description": "The route's index has no writable local layer"
          }
        },
        "security": [
          {
            "uploadToken": []
          }
        ]
      }
    },
    "/{route}/+api": {
      "get": {
        "tags": [
          "discovery"
        ],
        "summary": "Discover one index",
        "description": "A compact index document with URLs and client configuration snippets. Snippets appear only when the request has enough host context to render absolute URLs.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          }
        ],
        "responses": {
          "200": {
            "description": "The index discovery document",
            "content": {
              "application/json": {
                "example": {
                  "index": {
                    "capabilities": {
                      "legacy_json": false,
                      "metadata_siblings": true,
                      "project_status": false,
                      "provenance": false,
                      "simple_api_version": "1.1",
                      "simple_html": true,
                      "simple_json": true,
                      "uploads": true,
                      "volatile_deletes": true,
                      "yanking": true
                    },
                    "client_configuration": {
                      ".pypirc": "[distutils]\nindex-servers =\n    velodex\n\n[velodex]\nrepository = http://127.0.0.1:4433/root/pypi/\nusername = __token__\npassword = <upload-token>\n",
                      "pip.conf": "[global]\nindex-url = http://127.0.0.1:4433/root/pypi/simple/\n",
                      "uv.toml": "publish-url = \"http://127.0.0.1:4433/root/pypi/\"\n\n[[index]]\nname = \"velodex\"\nurl = \"http://127.0.0.1:4433/root/pypi/simple/\"\ndefault = true\n\n[pip]\nindex-url = \"http://127.0.0.1:4433/root/pypi/simple/\"\n"
                    },
                    "kind": "overlay",
                    "layers": [
                      "local",
                      "pypi"
                    ],
                    "name": "root/pypi",
                    "route": "root/pypi",
                    "upload_to": "local",
                    "uploads": true,
                    "urls": {
                      "api": "http://127.0.0.1:4433/root/pypi/+api",
                      "openapi": "http://127.0.0.1:4433/api-docs/openapi.json",
                      "simple": "http://127.0.0.1:4433/root/pypi/simple/",
                      "stats": "http://127.0.0.1:4433/stats?index=root%2Fpypi",
                      "status": "http://127.0.0.1:4433/+status",
                      "upload": "http://127.0.0.1:4433/root/pypi/",
                      "web": "http://127.0.0.1:4433/browse?index=root%2Fpypi"
                    }
                  },
                  "version": "0.0.1"
                }
              }
            }
          },
          "404": {
            "description": "No index at this route"
          }
        }
      }
    },
    "/{route}/files/{sha256}/{filename}": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "Download an artifact",
        "description": "Serves the blob if cached; otherwise fetches it from its source mirror, verifies the sha256, caches it, and serves it. The `{filename}` segment is display context and must be percent-encoded as one path segment. Responses are immutable (`Cache-Control: max-age=31536000`).",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "sha256",
            "in": "path",
            "description": "The artifact's sha256, lowercase hex",
            "required": true,
            "example": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
          },
          {
            "name": "filename",
            "in": "path",
            "description": "The display filename, percent-encoded as one path segment. Separators, traversal, and control characters are rejected.",
            "required": true,
            "example": "velodexpkg-1.0-py3-none-any.whl"
          }
        ],
        "responses": {
          "200": {
            "description": "The artifact bytes",
            "content": {
              "application/octet-stream": {}
            }
          },
          "400": {
            "description": "The digest is not 64 lowercase hex, or the filename is not a safe path segment"
          },
          "404": {
            "description": "No file with this digest is known"
          },
          "502": {
            "description": "The source mirror failed or the bytes did not match the digest"
          }
        }
      }
    },
    "/{route}/files/{sha256}/{filename}.metadata": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "Download PEP 658 core metadata",
        "description": "The `.metadata` sibling of a wheel: the wheel's core-metadata document, verified against the digest the index page advertised. pip and uv resolve through this instead of downloading whole wheels.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "sha256",
            "in": "path",
            "description": "The artifact's sha256, lowercase hex",
            "required": true,
            "example": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
          },
          {
            "name": "filename",
            "in": "path",
            "description": "The display filename, percent-encoded as one path segment. Separators, traversal, and control characters are rejected.",
            "required": true,
            "example": "velodexpkg-1.0-py3-none-any.whl.metadata"
          }
        ],
        "responses": {
          "200": {
            "description": "The core-metadata document",
            "content": {
              "application/octet-stream": {
                "example": "Metadata-Version: 2.1\nName: velodexpkg\nVersion: 1.0\nRequires-Python: >=3.8\n"
              }
            }
          },
          "404": {
            "description": "The wheel has no known metadata sibling"
          }
        }
      }
    },
    "/{route}/inspect/{sha256}/{filename}": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "List archive members",
        "description": "The file members of a cached wheel, zip, or gzipped tarball. Nested archives are not expanded unless the request names them with repeated `container` query parameters. Pass `member` to read one bounded text chunk.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "sha256",
            "in": "path",
            "description": "The artifact's sha256, lowercase hex",
            "required": true,
            "example": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
          },
          {
            "name": "filename",
            "in": "path",
            "description": "The display filename, percent-encoded as one path segment. Separators, traversal, and control characters are rejected.",
            "required": true,
            "example": "velodexpkg-1.0-py3-none-any.whl"
          },
          {
            "name": "container",
            "in": "query",
            "description": "Optional archive-member path to treat as the next archive level. Repeat in stack order.",
            "required": false,
            "example": "vendor/inner.zip"
          },
          {
            "name": "member",
            "in": "query",
            "description": "Optional text member path to read as a bounded chunk",
            "required": false,
            "example": "velodexpkg-1.0.dist-info/METADATA"
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Byte offset inside the selected member; defaults to 0",
            "required": false,
            "example": 262144
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum bytes to return, from 1 through 1048576; defaults to 262144",
            "required": false,
            "example": 262144
          }
        ],
        "responses": {
          "200": {
            "description": "The archive listing, or a text member chunk when `member` is set",
            "content": {
              "application/json": {
                "example": {
                  "filename": "velodexpkg-1.0-py3-none-any.whl",
                  "members": [
                    {
                      "kind": "text",
                      "path": "velodexpkg/__init__.py",
                      "previewable": true,
                      "size": 20
                    },
                    {
                      "kind": "archive",
                      "path": "vendor/inner.zip",
                      "previewable": false,
                      "size": 1102
                    },
                    {
                      "kind": "binary",
                      "path": "velodexpkg/data.bin",
                      "previewable": false,
                      "size": 8192
                    }
                  ]
                }
              },
              "text/plain; charset=utf-8": {
                "example": "Metadata-Version: 2.1\nName: velodexpkg\nVersion: 1.0\n"
              }
            }
          },
          "400": {
            "description": "Bad digest, unsafe filename, or archive nesting depth above the limit"
          },
          "404": {
            "description": "No file with this digest is known, or the member does not exist"
          },
          "413": {
            "description": "Nested archive size or listed entries exceed limits"
          },
          "415": {
            "description": "Not a supported archive type, or the selected member is not text"
          },
          "416": {
            "description": "The requested member offset is beyond the member size"
          },
          "422": {
            "description": "The archive cannot be read"
          }
        }
      }
    },
    "/{route}/inspect/{sha256}/{filename}/{member}": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "Read an archive member",
        "description": "Legacy path form for reading one root archive member as bounded text chunks. Prefer the query form when member names contain slashes or when inspecting nested archives.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "sha256",
            "in": "path",
            "description": "The artifact's sha256, lowercase hex",
            "required": true,
            "example": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
          },
          {
            "name": "filename",
            "in": "path",
            "description": "The display filename, percent-encoded as one path segment. Separators, traversal, and control characters are rejected.",
            "required": true,
            "example": "velodexpkg-1.0-py3-none-any.whl"
          },
          {
            "name": "member",
            "in": "path",
            "required": true,
            "example": "velodexpkg-1.0.dist-info/METADATA"
          }
        ],
        "responses": {
          "200": {
            "description": "The member content",
            "content": {
              "text/plain; charset=utf-8": {
                "example": "Metadata-Version: 2.1\nName: velodexpkg\nVersion: 1.0\n"
              }
            }
          },
          "404": {
            "description": "Unknown digest or member"
          },
          "415": {
            "description": "The member is not previewable text"
          },
          "416": {
            "description": "The requested offset is beyond the member size"
          }
        }
      }
    },
    "/{route}/simple/": {
      "get": {
        "tags": [
          "simple"
        ],
        "summary": "List projects",
        "description": "The projects velodex has observed on this index: everything uploaded, plus every mirrored project a client has asked for. An overlay unions its layers. JSON or HTML by `Accept`.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "Accept",
            "in": "header",
            "description": "`application/vnd.pypi.simple.v1+json` for PEP 691 JSON; anything else gets PEP 503 HTML",
            "required": false,
            "example": "application/vnd.pypi.simple.v1+json"
          }
        ],
        "responses": {
          "200": {
            "description": "The project list (PEP 691 shown; PEP 503 HTML without the JSON `Accept`)",
            "content": {
              "application/vnd.pypi.simple.v1+json": {
                "example": {
                  "meta": {
                    "api-version": "1.1"
                  },
                  "projects": [
                    {
                      "name": "requests"
                    },
                    {
                      "name": "velodexpkg"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "No index at this route"
          }
        }
      }
    },
    "/{route}/simple/{project}/": {
      "get": {
        "tags": [
          "simple"
        ],
        "summary": "Project detail",
        "description": "All files of one project, merged across overlay layers (first match per filename wins, versions union). File URLs point back at velodex's own `files/` route; `core-metadata` advertises the PEP 658 sibling.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "project",
            "in": "path",
            "description": "The normalized (PEP 503) project name",
            "required": true,
            "example": "requests"
          },
          {
            "name": "Accept",
            "in": "header",
            "description": "`application/vnd.pypi.simple.v1+json` for PEP 691 JSON; anything else gets PEP 503 HTML",
            "required": false,
            "example": "application/vnd.pypi.simple.v1+json"
          }
        ],
        "responses": {
          "200": {
            "description": "The project detail page",
            "content": {
              "application/vnd.pypi.simple.v1+json": {
                "example": {
                  "files": [
                    {
                      "core-metadata": {
                        "sha256": "2c26b46b68ffc68ff99b453c1d30413413422d706483bfa0f98a5e886266e7ae"
                      },
                      "filename": "velodexpkg-1.0-py3-none-any.whl",
                      "hashes": {
                        "sha256": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"
                      },
                      "requires-python": ">=3.8",
                      "size": 1832,
                      "url": "/root/pypi/files/9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08/velodexpkg-1.0-py3-none-any.whl",
                      "yanked": false
                    }
                  ],
                  "meta": {
                    "api-version": "1.1"
                  },
                  "name": "velodexpkg",
                  "versions": [
                    "1.0"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "No layer of this index has the project"
          },
          "502": {
            "description": "The upstream failed and nothing is cached"
          }
        }
      }
    },
    "/{route}/{project}/": {
      "delete": {
        "tags": [
          "publish"
        ],
        "summary": "Delete a project",
        "description": "Removes every uploaded file of the project. Requires the local layer to be `volatile`.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
            "required": true,
            "example": "root/pypi"
          },
          {
            "name": "project",
            "in": "path",
            "description": "The normalized (PEP 503) project name",
            "required": true,
            "example": "requests"
          },
          {
            "name": "version",
            "in": "path",
            "description": "One release version",
            "required": true,
            "example": "1.2.0"
          }
        ],
        "responses": {
          "200": {
            "description": "Done; the body counts affected files",
            "content": {
              "text/plain": {
                "example": "removed 3 file(s)"
              }
            }
          },
          "401": {
            "description": "Missing or wrong token"
          },
          "403": {
            "description": "The index is not volatile; delete is disabled"
          },
          "404": {
            "description": "Nothing matched"
          },
          "405": {
            "description": "The route's index has no writable local layer"
          }
        },
        "security": [
          {
            "uploadToken": []
          }
        ]
      }
    },
    "/{route}/{project}/{version}/": {
      "delete": {
        "tags": [
          "publish"
        ],
        "summary": "Delete a version",
        "description": "Removes the version's uploaded files outright. Requires the local layer to be `volatile`; for an overlay, the upstream files become visible again.",
        "parameters": [
          {
            "name": "route",
            "in": "path",
            "description": "The index route, for example `root/pypi`",
